# 🧠 BarberOS Engine - Configurações

# 1. OpenAI (Cérebro)
OPENAI_API_KEY=sk-....
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1

# 2. LangSmith (Observabilidade e Debug)
# Obtenha sua chave em https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_....
LANGCHAIN_PROJECT=barberos-engine

# 3. BarberOS API
APP_PORT=8000
APP_DEBUG=true
WEBHOOK_SECRET=sua-chave-segura-aqui

# 4. UzAPI (Opcional se o N8N já gerencia)
UZAPI_URL=https://api.v2.uzapi.com.br
UZAPI_TOKEN=...
