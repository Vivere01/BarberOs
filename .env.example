# ============================================
# BarberOS - Environment Configuration
# ============================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0
SECRET_KEY=your-secret-key-change-in-production

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=1024

# --- LangSmith (Observability) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langsmith-api-key
LANGCHAIN_PROJECT=barberos-production
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./barberos.db

# --- Redis (Session/Cache) ---
REDIS_URL=redis://localhost:6379/0

# --- UzaAPI (WhatsApp) ---
UZAPI_BASE_URL=https://api.uzapi.com.br
UZAPI_TOKEN=your-uzapi-token

# --- CashBarber Integration ---
CASHBARBER_BASE_URL=https://app.sistemacashbarber.com.br
CASHBARBER_LOGIN_ENDPOINT=/api/auth/login

# --- AppBarber Integration ---
APPBARBER_BASE_URL=https://admin.appbarber.com.br
APPBARBER_LOGIN_ENDPOINT=/api/auth/login

# --- Sentry (Error Tracking) ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# --- ChromaDB (Vector Store) ---
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION_NAME=barbershop_knowledge

# --- N8N Webhook ---
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# --- Guardrails ---
MAX_RESPONSE_LENGTH=500
HALLUCINATION_THRESHOLD=0.7
ENABLE_PII_FILTER=true
ENABLE_HUMAN_HANDOFF=true
HUMAN_HANDOFF_CONFIDENCE_THRESHOLD=0.4
